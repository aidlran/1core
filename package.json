{
  "name": "1core",
  "version": "0.1.0",
  "private": true,
  "description": "1core app suite monorepo",
  "homepage": "https://github.com/1coreio/1core#readme",
  "bugs": "https://github.com/1coreio/1core/issues",
  "repository": "github:1coreio/1core",
  "license": "AGPL-3.0-only",
  "author": "Aidan Loughran",
  "type": "module",
  "bin": {
    "1core-note": "apps/note/cli.mjs",
    "1core-vault": "apps/vault/cli.mjs"
  },
  "workspaces": [
    "apps/*",
    "lib/*"
  ],
  "scripts": {
    "build": "npm run build -w lib/astrobase",
    "check": "tsc --noEmit",
    "ci": "conc npm:check npm:lint npm:test",
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "env-paths": "3.0.0"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
